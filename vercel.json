{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "buildCommand": "npm install && npm run build",
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://website-desa-tanjung-harapan.vercel.app/",
        "LOG_CHANNEL": "stderr"
    }
}